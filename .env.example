# Local API only. Never commit real production secrets.
PORT=3333
HOST=127.0.0.1
JWT_SECRET=replace-with-a-long-random-secret-before-production
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3000

# Temporary Railway preview only. It permits a non-persistent demo store in
# production mode but never enables development token creation.
ALLOW_DEMO_STORE=false

# Production requires PostgreSQL. The project has a narrow Postgres adapter
# for catalog, Studio ordering, comments, media metadata and audit records;
# it does not yet replace the separate media-processing or entitlement stack.
DATABASE_URL=postgresql://user:password@host:5432/sakhatube

# Studio staff accounts (production login, until OIDC/MFA lands). JSON array
# of { email, passwordHash, roles }. Generate each entry with:
#   npm run staff:hash-password -- you@sakhatube.ru superadmin
# Never put a plaintext password here.
STAFF_ACCOUNTS_JSON=[]
