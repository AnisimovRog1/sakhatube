# Local API only. Never commit real production secrets.
PORT=3333
HOST=127.0.0.1
JWT_SECRET=replace-with-a-long-random-secret-before-production
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3000

# Temporary Railway preview only. It permits a non-persistent demo store in
# production mode but never enables development token creation.
ALLOW_DEMO_STORE=false

# Production requires this variable. The current API starter deliberately has
# no database adapter yet, so do not use it as a production deployment.
DATABASE_URL=postgresql://user:password@host:5432/sakhatube
