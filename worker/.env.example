# Base URL of the main SakhaTube API service (the claim/settle endpoints).
SAKHATUBE_API_URL=http://127.0.0.1:3333

# Must equal MEDIA_WORKER_TOKEN on the API service.
MEDIA_WORKER_TOKEN=replace-with-the-same-value-the-api-has

# Same Postgres the API uses. The worker never runs migrations.
DATABASE_URL=postgresql://user:password@host:5432/sakhatube

# Same S3-compatible bucket the API uploads sources to.
S3_ENDPOINT=https://example.storageapi.dev
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=replace-me
S3_REGION=auto

# Optional.
WORKER_ID=worker-1
WORKER_POLL_INTERVAL_MS=8000
