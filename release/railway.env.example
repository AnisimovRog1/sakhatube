# Copy these names to Railway Variables. Never commit real values.
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=
DELETION_VERIFICATION_SECRET=
EMAIL_VERIFICATION_SECRET=
PUBLIC_APP_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com

# The endpoint must accept a JSON POST with: to, subject, text,
# verificationUrl, requestId and expiresAt. Use a provider integration or a
# private mail worker. Do not point it to a public browser URL.
MAILER_WEBHOOK_URL=
MAILER_WEBHOOK_BEARER_TOKEN=

# One-time email-verification links are valid for 24 hours by default.
# Use a value from 60000 to 604800000 milliseconds only when required.
EMAIL_VERIFICATION_TTL_MS=86400000

# Keep false until StoreKit + Google Play Billing and server validation are live.
PAYMENTS_ENABLED=false

# Private object storage for source uploads; never expose its credentials in a client.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
